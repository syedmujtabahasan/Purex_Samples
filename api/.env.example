# ==================== PUREX API — ENVIRONMENT VARIABLES ====================
# Copy this to .env and fill in real values. NEVER commit .env to git.

# Database
DB_HOST=localhost
DB_NAME=your_database_name
DB_USER=your_database_user
DB_PASS=your_database_password

# JWT — generate with: openssl rand -hex 32
JWT_SECRET=CHANGE_ME_TO_A_RANDOM_64_CHAR_STRING
JWT_EXPIRY=14400

# CORS — comma-separated allowed origins (no trailing slash)
ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# Rate limiting
RATE_LIMIT_LOGIN=5
RATE_LIMIT_LOGIN_WINDOW=900
RATE_LIMIT_CONTACT=3
RATE_LIMIT_CONTACT_WINDOW=600
RATE_LIMIT_API=120
RATE_LIMIT_API_WINDOW=60
